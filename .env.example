# AGROIntel Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://agrointel_user:secure_password_123@postgres:5432/agrointel_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ============================================
# InfluxDB Configuration (Time-series Data)
# ============================================
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=agrointel
INFLUXDB_BUCKET=agrointel_timeseries
INFLUXDB_TOKEN=admin_password_123
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin_password_123

# ============================================
# Redis Configuration (Cache & Sessions)
# ============================================
REDIS_URL=redis://:redis_password_123@redis:6379/0
REDIS_PASSWORD=redis_password_123
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# RabbitMQ Configuration (Message Queue)
# ============================================
RABBITMQ_URL=amqp://agrointel:rabbitmq_password_123@rabbitmq:5672/
RABBITMQ_USERNAME=agrointel
RABBITMQ_PASSWORD=rabbitmq_password_123
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/

# ============================================
# JWT & Authentication
# ============================================
JWT_SECRET_KEY=your-very-secret-key-min-32-characters-long-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# ============================================
# External APIs
# ============================================
# OpenWeather API for weather forecasting
OPENWEATHER_API_KEY=your_openweathermap_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org

# Google Maps API for geolocation
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Sentinel Hub API for satellite imagery
SENTINEL_HUB_API_KEY=your_sentinel_hub_api_key

# ============================================
# Email Configuration
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@agrointel.com
SMTP_FROM_NAME=AGROIntel
MAIL_USE_TLS=true

# ============================================
# AWS Configuration (S3, CloudWatch, etc)
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=agrointel-files
AWS_S3_BUCKET_PUBLIC=agrointel-public
AWS_CLOUDWATCH_LOG_GROUP=/agrointel/logs

# ============================================
# Google Cloud Configuration (Optional)
# ============================================
GCP_PROJECT_ID=your_gcp_project_id
GCP_CREDENTIALS_PATH=/path/to/credentials.json

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.agrointel.com

# ============================================
# ML Configuration
# ============================================
ML_MODEL_PATH=./ml_models/models/
ML_USE_GPU=true
TF_CPP_MIN_LOG_LEVEL=2
TF_FORCE_GPU_ALLOW_GROWTH=true

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql://agrointel_user:secure_password_123@postgres:5432/mlflow
MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://agrointel-ml-artifacts/

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=amqp://agrointel:rabbitmq_password_123@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://:redis_password_123@redis:6379/0
CELERY_TIMEZONE=UTC

# ============================================
# Monitoring & Observability
# ============================================
# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana
GRAFANA_ADMIN_PASSWORD=admin_password_123
GRAFANA_ADMIN_USER=admin

# Datadog (Optional)
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DATADOG_ENABLED=false

# Sentry (Error tracking)
SENTRY_DSN=your_sentry_dsn

# ============================================
# Security
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.agrointel.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=*

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Session configuration
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
SESSION_TIMEOUT_MINUTES=30

# ============================================
# Subscription & Billing
# ============================================
STRIPE_API_KEY=your_stripe_api_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
CURRENCY=USD

# ============================================
# IoT & Sensors
# ============================================
# MQTT Broker for sensor data
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_password
MQTT_TOPICS=sensors/+/data

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/api/v1/ws
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key
VITE_MAPBOX_TOKEN=your_mapbox_token
VITE_APP_NAME=AGROIntel
VITE_APP_VERSION=1.0.0

# ============================================
# Feature Flags
# ============================================
FEATURE_REAL_TIME_MONITORING=true
FEATURE_YIELD_PREDICTION=true
FEATURE_DISEASE_DETECTION=true
FEATURE_IRRIGATION_OPTIMIZATION=true
FEATURE_MARKETPLACE=false
FEATURE_MOBILE_APP=false
FEATURE_DRONE_INTEGRATION=false

# ============================================
# Development/Testing
# ============================================
TEST_DATABASE_URL=postgresql://agrointel_user:secure_password_123@postgres:5432/agrointel_test_db
PYTEST_TIMEOUT=300
SKIP_EXTERNAL_API_TESTS=false
MOCK_EXTERNAL_APIS=true

# ============================================
# Performance
# ============================================
# Cache settings
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=512

# Database connection pooling
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# API pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# Internationalization
# ============================================
SUPPORTED_LANGUAGES=en,hi,ur,ta,te,kn,ml
DEFAULT_LANGUAGE=en
TIMEZONE=UTC

# ============================================
# File Upload Configuration
# ============================================
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,xls,xlsx,csv
UPLOAD_DIRECTORY=./uploads/
